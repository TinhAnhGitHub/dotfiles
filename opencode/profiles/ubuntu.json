{
  "$schema": "https://opencode.ai/config.json",
  "shell": "bash",
  "mcp": {
    "codebase-memory-mcp": {
      "type": "local",
      "command": ["{env:CODEBASE_MEMORY_MCP_BIN}"],
      "enabled": true,
      "timeout": 10000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "ast-grep": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ],
      "enabled": true
    },
    "grep-app": {
      "type": "local",
      "command": ["node", "{env:GREP_APP_MCP_PATH}"],
      "enabled": true,
      "timeout": 30000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      },
      "enabled": true
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "bash",
        "-lc",
        "uv run ruff check --select I --fix \"$FILE\" && uv run ruff format \"$FILE\""
      ],
      "extensions": [".py", ".pyi"]
    }
  }
}
